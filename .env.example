# Copy to .env and edit before first start:
#   cp .env.example .env

# Process name disguise (default: nginx)
PROCESS_NAME=nginx

# 3x-ui panel credentials
PANEL_USER=admin
PANEL_PASS=changeme

# Panel port — default mimics cPanel SSL (2083)
PANEL_PORT=2083

# Panel base path (makes URL less obvious)
PANEL_PATH=/get
